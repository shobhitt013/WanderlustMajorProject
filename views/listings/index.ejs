<% layout("/layouts/boilerplate") %>

<style>

.filters-container{
    display:flex;
    align-items:center;
    gap:1rem;
    margin-top:2rem;
    margin-bottom:0.5rem;
}

#filters{
    display: flex;
    align-items: center;
    gap: 2rem;

    overflow-x: auto;
    overflow-y: hidden;
    white-space: nowrap;
    scroll-behavior: smooth;

    flex: 1;

    /* Better vertical spacing */
    padding-top: 0.4rem;
    padding-bottom: 0.25rem;
}

/* Hide scrollbar */

#filters::-webkit-scrollbar{
    display: none;
}

#filters{
    scrollbar-width: none;
    -ms-overflow-style: none;
}
/* Individual Filter */

.filter{
    flex: 0 0 auto;
    text-align: center;
    opacity: .7;
    transition: .3s;
}

.filter:hover{
    opacity: 1;
    cursor: pointer;
    transform: scale(1.08);
}

.filter i{
    font-size: 1.25rem;
}

.filter p{
    margin-top: 0.25rem;
    margin-bottom: 0;
    font-size: .82rem;
}

/* Tax Toggle */

.tax-toggle{
    border:1px solid #ddd;
    border-radius:15px;
    padding:.8rem 1rem;
    flex-shrink:0;
    background:#fff;
}

.tax-info{
    display:none;
}

/* Scroll Button */

.scroll-btn{
    width:42px;
    height:42px;
    border:none;
    border-radius:50%;
    background:#fff;
    box-shadow:0 2px 8px rgba(0,0,0,.15);
    transition:.2s;
}

.scroll-btn:hover{
    background:#f5f5f5;
}


@media(max-width:992px){

    .filters-container{
        flex-wrap:wrap;
    }

    .tax-toggle{
        width:100%;
        display:flex;
        justify-content:center;
    }

}

@media(max-width:768px){

    #filters{
        gap:1.2rem;
    }

    .filter{
        min-width:60px;
    }

    .filter i{
        font-size:1rem;
    }

    .filter p{
        font-size:.72rem;
    }

    .scroll-btn{
        display:none;
    }
}
</style>


<div class="filters-container">

    <div id="filters">

       <a href="/listings?category=Trending" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
</a>

<a href="/listings?category=Rooms" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
</a>

<a href="/listings?category=Iconic Cities" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-mountain-city"></i>
    <p>Iconic Cities</p>
</a>

<a href="/listings?category=Mountains" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
</a>

<a href="/listings?category=Castles" class="filter text-decoration-none text-dark">
    <i class="fa-brands fa-fort-awesome"></i>
    <p>Castles</p>
</a>

<a href="/listings?category=Amazing Pools" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-person-swimming"></i>
    <p>Amazing Pools</p>
</a>

<a href="/listings?category=Camping" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
</a>

<a href="/listings?category=Farms" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-cow"></i>
    <p>Farms</p>
</a>

<a href="/listings?category=Arctic" class="filter text-decoration-none text-dark">
    <i class="fa-regular fa-snowflake"></i>
    <p>Arctic</p>
</a>

<a href="/listings?category=Domes" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-igloo"></i>
    <p>Domes</p>
</a>

<a href="/listings?category=Houseboats" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-sailboat"></i>
    <p>Houseboats</p>
</a>

<a href="/listings?category=Forests" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-tree"></i>
    <p>Forests</p>
</a>

<a href="/listings?category=Beaches" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-umbrella-beach"></i>
    <p>Beaches</p>
</a>

<a href="/listings?category=Apartments" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-building"></i>
    <p>Apartments</p>
</a>

<a href="/listings?category=Countryside" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-tree-city"></i>
    <p>Countryside</p>
</a>

<a href="/listings?category=Lakefront" class="filter text-decoration-none text-dark">
    <i class="fa-solid fa-water"></i>
    <p>Lakefront</p>
</a>

    </div>

    <div class="tax-toggle">

        <div class="form-check form-switch">

            <input
                class="form-check-input"
                type="checkbox"
                id="flexSwitchCheckDefault">

            <label
                class="form-check-label"
                for="flexSwitchCheckDefault">

                Display total after taxes

            </label>

        </div>

    </div>

    <button class="scroll-btn">
        <i class="fa-solid fa-chevron-right"></i>
    </button>

</div>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4 mt-1">

    <% for(let listing of allListings){ %>

        <a href="/listings/<%= listing._id %>" class="listing-link">

            <div class="card listing-card h-100">

                <img
                    src="<%= listing.image.url %>"
                    class="card-img-top"
                    alt="listing_image"
                    style="height:20rem; object-fit:cover;">

                <div class="card-img-overlay"></div>

                <div class="card-body">

                    <p class="card-text">

                        <b><%= listing.title %></b>

                        <br>

                        &#8377;
                        <%= listing.price.toLocaleString("en-IN") %>
                        / night

                        <span class="tax-info">
                            &nbsp; +18% GST
                        </span>

                    </p>

                </div>

            </div>

        </a>

    <% } %>

</div>



<script>

let taxSwitch = document.getElementById("flexSwitchCheckDefault");

taxSwitch.addEventListener("click",()=>{

    let taxInfo=document.getElementsByClassName("tax-info");

    for(let info of taxInfo){

        if(taxSwitch.checked){

            info.style.display="inline";

        }

        else{

            info.style.display="none";

        }

    }

});

const filters=document.getElementById("filters");

const scrollBtn=document.querySelector(".scroll-btn");

scrollBtn.addEventListener("click",()=>{

    filters.scrollBy({

        left:300,

        behavior:"smooth"

    });

});

</script>